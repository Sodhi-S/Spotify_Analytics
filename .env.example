# Last.fm API
LASTFM_API_KEY=
LASTFM_API_SECRET=
LASTFM_USERNAME=

# Database (PostgreSQL - Phases 1-6)
DB_CONNECTION_STRING=
WAREHOUSE_SCHEMA=public

# Database (Snowflake - Phase 7)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=

# Weather
OPENMETEO_CITY=Toronto

# DateTime insights: IANA timezone used to localize scrobble timestamps
# (hour-of-day, day-of-week, month buckets). Read by dbt at build time.
LISTENING_TIMEZONE=America/Toronto

# Slack
SLACK_WEBHOOK_URL=

# API / frontend
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
VITE_API_BASE_URL=http://localhost:8000
VITE_HIDE_REAL_NUMBERS=false
DBT_EXECUTABLE=dbt
APP_SESSION_DAYS=30
FRONTEND_AUTH_REDIRECT_URL=http://localhost:3000
SESSION_COOKIE_NAME=music_intelligence_session

# Mood model
MOOD_MODEL_PATH=
MUSIC2EMO_REPO_PATH=/tmp/Music2Emotion
MUSIC2EMO_MODEL_WEIGHTS=/tmp/Music2Emotion/saved_models/J_all.ckpt
MUSIC2EMO_RUN_AFTER_INGEST=true
MUSIC2EMO_PREVIEW_LIMIT=100
MUSIC2EMO_INFERENCE_LIMIT=25
IMAGE_ENRICHMENT_RUN_AFTER_INGEST=true
IMAGE_ENRICHMENT_TRACK_LIMIT=100
IMAGE_ENRICHMENT_ARTIST_LIMIT=100
IMAGE_ENRICHMENT_ARTIST_ALBUM_FALLBACK=false
TARGET_SAMPLE_RATE=22050
MOOD_NULL_RATE_THRESHOLD=0.75
